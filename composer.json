{
    "name": "etkinlik/php-sdk",
    "description": "API for integrating with event content aggregated and categorized from many sources and organizers. Use this documentation to build applications on top of Etkinlik.io event data.",
    "keywords": [
        "openapitools",
        "openapi-generator",
        "openapi",
        "php",
        "sdk",
        "rest",
        "api"
    ],
    "homepage": "https://etkinlik.io/api-bilgi",
    "license": "MIT",
    "authors": [
        {
            "name": "OpenAPI",
            "homepage": "https://openapi-generator.tech"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "EtkinlikIo\\Api\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EtkinlikIo\\Api\\Test\\": "test/"
        }
    },
    "type": "library",
    "support": {
        "issues": "https://github.com/etkinlik/php-sdk/issues",
        "source": "https://github.com/etkinlik/php-sdk"
    }
}
